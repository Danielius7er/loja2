---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getSessionFromCookie } from "../lib/auth";

export const prerender = false;

const cookie = Astro.request.headers.get("cookie");
if (getSessionFromCookie(cookie)) {
  return Astro.redirect("/admin-panel");
}
---

<BaseLayout title="Entrar — Cavilson Ferreira">
  <main class="mx-auto flex min-h-screen max-w-md flex-col justify-center px-5 py-16">
    <p class="text-xs font-medium uppercase tracking-[0.3em] text-muted">Área reservada</p>
    <h1 class="mt-3 font-[Manrope] text-2xl font-semibold">Painel Cavilson Ferreira</h1>
    <p class="mt-2 text-sm text-muted">Introduza a palavra-passe para gerir os produtos.</p>

    <form id="login-form" class="mt-8 space-y-4">
      <div>
        <label for="password" class="mb-1.5 block text-xs font-medium uppercase tracking-wider">
          Palavra-passe
        </label>
        <input
          id="password"
          name="password"
          type="password"
          required
          autocomplete="current-password"
          class="w-full rounded-xl border border-border px-4 py-3 text-sm outline-none focus:border-text"
        />
      </div>
      <p id="login-error" class="hidden text-sm text-red-600"></p>
      <button
        type="submit"
        class="w-full rounded-full bg-text py-3 text-xs font-semibold uppercase tracking-wider text-bg transition hover:opacity-90"
      >
        Entrar
      </button>
    </form>
    <a href="/" class="mt-8 text-center text-xs text-muted hover:text-text">← Voltar à loja</a>
  </main>
</BaseLayout>

<script>
  const form = document.getElementById("login-form") as HTMLFormElement;
  const errorEl = document.getElementById("login-error") as HTMLParagraphElement;

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    errorEl.classList.add("hidden");
    const password = (new FormData(form).get("password") as string) || "";

    const res = await fetch("/api/auth", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ password }),
    });

    if (res.ok) {
      window.location.href = "/admin-panel";
      return;
    }

    errorEl.textContent = "Palavra-passe incorrecta. Tente novamente.";
    errorEl.classList.remove("hidden");
  });
</script>
