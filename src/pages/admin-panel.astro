---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getSessionFromCookie } from "../lib/auth";

export const prerender = false;

const cookie = Astro.request.headers.get("cookie");
if (!getSessionFromCookie(cookie)) {
  return Astro.redirect("/admin");
}
---

<BaseLayout title="Painel — Cavilson Ferreira">
  <main class="mx-auto min-h-screen max-w-4xl px-5 py-10 md:px-8">
    <header class="flex flex-col gap-4 border-b border-border pb-8 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <p class="text-xs font-medium uppercase tracking-[0.3em] text-muted">Gestão</p>
        <h1 class="mt-2 font-[Manrope] text-2xl font-semibold">Os seus produtos</h1>
      </div>
      <div class="flex gap-3">
        <a href="/" class="rounded-full border border-border px-4 py-2 text-xs uppercase tracking-wider hover:border-text">
          Ver loja
        </a>
        <button
          id="btn-new"
          type="button"
          class="rounded-full bg-text px-4 py-2 text-xs font-semibold uppercase tracking-wider text-bg"
        >
          Novo produto
        </button>
      </div>
    </header>

    <p id="status" class="mt-6 hidden rounded-xl border px-4 py-3 text-sm"></p>

    <div id="product-list" class="mt-8 space-y-4"></div>

    <dialog
      id="product-dialog"
      class="w-[calc(100%-2rem)] max-w-lg rounded-2xl border border-border bg-bg p-0 shadow-xl backdrop:bg-black/40 open:flex open:flex-col"
    >
      <form id="product-form" class="flex flex-col gap-0">
        <div class="border-b border-border px-6 py-4">
          <h2 id="dialog-title" class="font-[Manrope] text-lg font-semibold">Novo produto</h2>
        </div>
        <div class="space-y-4 px-6 py-5">
          <input type="hidden" id="product-id" name="id" />

          <div>
            <label class="mb-1 block text-xs font-medium uppercase tracking-wider" for="name">Nome</label>
            <input id="name" name="name" required class="w-full rounded-xl border border-border px-4 py-2.5 text-sm outline-none focus:border-text" />
          </div>

          <div>
            <label class="mb-1 block text-xs font-medium uppercase tracking-wider" for="description">
              Descrição do produto
            </label>
            <p class="mb-2 text-xs text-muted">
              Aparece quando o cliente clica na imagem na loja. Obrigatória para novos produtos.
            </p>
            <textarea
              id="description"
              name="description"
              rows="4"
              required
              minlength="10"
              maxlength="800"
              placeholder="Ex.: Armação redonda em acetato tartaruga, leve e confortável..."
              class="w-full rounded-xl border border-border px-4 py-2.5 text-sm outline-none focus:border-text"
            ></textarea>
          </div>

          <div class="grid gap-4 sm:grid-cols-2">
            <div>
              <label class="mb-1 block text-xs font-medium uppercase tracking-wider" for="price">
                Preço (Kz)
              </label>
              <input id="price" name="price" type="number" min="0" required class="w-full rounded-xl border border-border px-4 py-2.5 text-sm outline-none focus:border-text" />
            </div>
            <div>
              <label class="mb-1 block text-xs font-medium uppercase tracking-wider" for="whatsapp">
                WhatsApp
              </label>
              <input id="whatsapp" name="whatsapp" required placeholder="244900000000" class="w-full rounded-xl border border-border px-4 py-2.5 text-sm outline-none focus:border-text" />
            </div>
          </div>

          <div>
            <label class="mb-1 block text-xs font-medium uppercase tracking-wider">Imagem</label>
            <div class="flex flex-col gap-3 sm:flex-row sm:items-center">
              <input id="image" name="image" type="hidden" />
              <img id="preview" alt="" class="hidden h-24 w-24 rounded-xl border border-border object-cover" />
              <label
                class="inline-flex cursor-pointer items-center justify-center rounded-full border border-border px-4 py-2 text-xs uppercase tracking-wider hover:border-text"
              >
                Carregar foto
                <input id="file" type="file" accept="image/*" class="sr-only" />
              </label>
            </div>
          </div>

          <label class="flex items-center gap-2 text-sm">
            <input id="inStock" name="inStock" type="checkbox" checked class="h-4 w-4 rounded border-border" />
            Disponível para venda
          </label>
        </div>
        <div class="flex justify-end gap-3 border-t border-border px-6 py-4">
          <button type="button" id="btn-cancel" class="rounded-full border border-border px-4 py-2 text-xs uppercase">
            Cancelar
          </button>
          <button type="submit" class="rounded-full bg-text px-5 py-2 text-xs font-semibold uppercase text-bg">
            Guardar
          </button>
        </div>
      </form>
    </dialog>
  </main>
</BaseLayout>

<script lang="ts">
  import type { Product } from "../types/product";

  const listEl = document.getElementById("product-list")!;
  const dialog = document.getElementById("product-dialog") as HTMLDialogElement;
  const form = document.getElementById("product-form") as HTMLFormElement;
  const statusEl = document.getElementById("status")!;
  const dialogTitle = document.getElementById("dialog-title")!;
  const preview = document.getElementById("preview") as HTMLImageElement;
  const imageInput = document.getElementById("image") as HTMLInputElement;
  const fileInput = document.getElementById("file") as HTMLInputElement;

  let editingId: number | null = null;

  function showStatus(msg: string, ok = true) {
    statusEl.textContent = msg;
    statusEl.className = `mt-6 rounded-xl border px-4 py-3 text-sm ${
      ok ? "border-border text-muted" : "border-red-200 text-red-700"
    }`;
    statusEl.classList.remove("hidden");
    setTimeout(() => statusEl.classList.add("hidden"), 4000);
  }

  function formatPrice(n: number) {
    const amount = n.toLocaleString("pt-PT", { maximumFractionDigits: 0 });
    return `${amount.replace(/\s/g, ".")} Kz`;
  }

  async function api<T>(url: string, init?: RequestInit): Promise<T> {
    const res = await fetch(url, init);
    if (res.status === 401) {
      window.location.href = "/admin";
      throw new Error("unauthorized");
    }
    if (!res.ok) throw new Error("request failed");
    return res.json() as Promise<T>;
  }

  function renderList(products: Product[]) {
    if (products.length === 0) {
      listEl.innerHTML =
        '<p class="rounded-2xl border border-dashed border-border py-12 text-center text-sm text-muted">Ainda não há produtos. Clique em «Novo produto».</p>';
      return;
    }

    listEl.innerHTML = products
      .map(
        (p) => `
      <article class="flex gap-4 rounded-2xl border border-border p-4">
        <img src="${p.image}" alt="" class="h-20 w-20 shrink-0 rounded-xl object-cover bg-[#f7f7f7]" />
        <div class="min-w-0 flex-1">
          <div class="flex flex-wrap items-start justify-between gap-2">
            <h3 class="font-medium">${escapeHtml(p.name)}</h3>
            <span class="text-xs uppercase ${p.inStock ? "text-muted" : "text-text font-semibold"}">
              ${p.inStock ? "Em stock" : "Esgotado"}
            </span>
          </div>
          <p class="mt-1 text-sm text-muted line-clamp-2">${escapeHtml(p.description)}</p>
          <p class="mt-2 text-sm font-medium">${formatPrice(p.price)}</p>
          <div class="mt-3 flex flex-wrap gap-2">
            <button type="button" data-edit="${p.id}" class="rounded-full border border-border px-3 py-1.5 text-[11px] uppercase tracking-wider hover:border-text">Editar</button>
            <button type="button" data-stock="${p.id}" class="rounded-full border border-border px-3 py-1.5 text-[11px] uppercase tracking-wider hover:border-text">${p.inStock ? "Marcar esgotado" : "Marcar disponível"}</button>
            <button type="button" data-delete="${p.id}" class="rounded-full border border-border px-3 py-1.5 text-[11px] uppercase tracking-wider text-red-700 hover:border-text">Apagar</button>
          </div>
        </div>
      </article>`
      )
      .join("");

    listEl.querySelectorAll("[data-edit]").forEach((btn) => {
      btn.addEventListener("click", () => openEdit(Number((btn as HTMLElement).dataset.edit)));
    });
    listEl.querySelectorAll("[data-stock]").forEach((btn) => {
      btn.addEventListener("click", () => toggleStock(Number((btn as HTMLElement).dataset.stock)));
    });
    listEl.querySelectorAll("[data-delete]").forEach((btn) => {
      btn.addEventListener("click", () => removeProduct(Number((btn as HTMLElement).dataset.delete)));
    });
  }

  function escapeHtml(s: string) {
    return s.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;");
  }

  async function load() {
    const products = await api<Product[]>("/api/products");
    renderList(products);
  }

  function openNew() {
    editingId = null;
    dialogTitle.textContent = "Novo produto";
    form.reset();
    imageInput.value = "";
    preview.classList.add("hidden");
    (document.getElementById("price") as HTMLInputElement).value = "10700";
    (document.getElementById("inStock") as HTMLInputElement).checked = true;
    dialog.showModal();
  }

  async function openEdit(id: number) {
    const products = await api<Product[]>("/api/products");
    const p = products.find((x) => x.id === id);
    if (!p) return;
    editingId = id;
    dialogTitle.textContent = "Editar produto";
    (document.getElementById("product-id") as HTMLInputElement).value = String(id);
    (document.getElementById("name") as HTMLInputElement).value = p.name;
    (document.getElementById("description") as HTMLTextAreaElement).value = p.description;
    (document.getElementById("price") as HTMLInputElement).value = String(p.price);
    (document.getElementById("whatsapp") as HTMLInputElement).value = p.whatsapp;
    imageInput.value = p.image;
    preview.src = p.image;
    preview.classList.remove("hidden");
    (document.getElementById("inStock") as HTMLInputElement).checked = p.inStock;
    dialog.showModal();
  }

  async function toggleStock(id: number) {
    const products = await api<Product[]>("/api/products");
    const p = products.find((x) => x.id === id);
    if (!p) return;
    await api(`/api/products/${id}`, {
      method: "PUT",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ ...p, inStock: !p.inStock }),
    });
    showStatus("Estado de stock actualizado.");
    await load();
  }

  async function removeProduct(id: number) {
    if (!confirm("Apagar este produto?")) return;
    await api(`/api/products/${id}`, { method: "DELETE" });
    showStatus("Produto apagado.");
    await load();
  }

  fileInput.addEventListener("change", async () => {
    const file = fileInput.files?.[0];
    if (!file) return;
    const fd = new FormData();
    fd.append("file", file);
    try {
      const { url } = await api<{ url: string }>("/api/upload", { method: "POST", body: fd });
      imageInput.value = url;
      preview.src = url;
      preview.classList.remove("hidden");
    } catch {
      showStatus("Não foi possível carregar a imagem.", false);
    }
    fileInput.value = "";
  });

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    const data = {
      name: (document.getElementById("name") as HTMLInputElement).value.trim(),
      description: (document.getElementById("description") as HTMLTextAreaElement).value.trim(),
      price: Number((document.getElementById("price") as HTMLInputElement).value),
      whatsapp: (document.getElementById("whatsapp") as HTMLInputElement).value.trim(),
      image: imageInput.value,
      inStock: (document.getElementById("inStock") as HTMLInputElement).checked,
    };

    if (!data.image) {
      showStatus("Adicione uma foto ao produto.", false);
      return;
    }

    if (!data.description || data.description.length < 10) {
      showStatus("Escreva uma descrição com pelo menos 10 caracteres.", false);
      return;
    }

    try {
      if (editingId) {
        await api(`/api/products/${editingId}`, {
          method: "PUT",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(data),
        });
        showStatus("Produto actualizado.");
      } else {
        await api("/api/products", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(data),
        });
        showStatus("Produto criado.");
      }
      dialog.close();
      await load();
    } catch {
      showStatus("Verifique os dados e tente novamente.", false);
    }
  });

  document.getElementById("btn-new")?.addEventListener("click", openNew);
  document.getElementById("btn-cancel")?.addEventListener("click", () => dialog.close());

  load().catch(() => showStatus("Erro ao carregar produtos.", false));
</script>
