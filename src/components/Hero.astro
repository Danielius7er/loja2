---
import { BRAND } from "../config/brand";
---

<section class="mx-auto max-w-6xl px-5 pb-10 pt-12 md:px-8 md:pt-16">
  <div class="rounded-3xl border border-border bg-bg px-6 py-12 text-center shadow-[0_20px_50px_rgba(0,0,0,0.04)] md:px-14 md:py-16">
    <p class="text-xs font-medium uppercase tracking-[0.4em] text-muted">
      {BRAND.tagline} · {BRAND.name}
    </p>
    <h1 class="mt-4 font-[Manrope] text-3xl font-semibold tracking-tight md:text-5xl">
      Óculos de assinatura, feitos para destacar
    </h1>
    <p class="mx-auto mt-5 max-w-xl text-sm leading-relaxed text-muted md:text-base">
      Explore a coleção abaixo. Cada modelo inclui galeria interactiva, variantes de cor e descrição
      ao toque — tudo por <strong class="text-text">10.700 Kz</strong>.
    </p>
    <a
      href="#produtos"
      class="mt-8 inline-flex items-center justify-center rounded-full border border-text px-8 py-3 text-xs font-semibold uppercase tracking-[0.2em] transition hover:bg-text hover:text-bg"
    >
      Explorar coleção
    </a>
  </div>
</section>
